{
  "name": "supergraph",
  "version": "1.1.25",
  "description": "Monorepo intelligence — structural analysis, deep audits, and interactive visualization",
  "private": true,
  "workspaces": [
    "packages/graph",
    "packages/flow",
    "packages/scripts",
    "packages/dashboard"
  ],
  "module": "src/index.ts",
  "bin": {
    "supergraph": "src/index.ts"
  },
  "scripts": {
    "start": "bun serve.ts",
    "build": "bun run packages/scripts/build.ts",
    "release": "bun run packages/scripts/release.ts",
    "test": "bun test --recursive",
    "typecheck": "bun run --filter='*' typecheck",
    "audit-prep": "bun packages/scripts/audit-prep.ts",
    "supergraph": "bun packages/scripts/supergraph.ts",
    "pkg-graph": "bun packages/scripts/pkg-graph.ts",
    "check-health": "bun packages/scripts/check-health.ts",
    "demo": "bun src/ui/graph-animation.ts",
    "install-local": "bash install.sh --local"
  },
  "devDependencies": {
    "bun-types": "latest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  }
}
