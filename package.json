{
  "name": "supergraph",
  "version": "1.0.2",
  "description": "Monorepo intelligence — structural analysis, deep audits, and interactive visualization",
  "private": true,
  "workspaces": [
    "graph",
    "flow",
    "scripts",
    "dashboard"
  ],
  "module": "src/index.ts",
  "bin": {
    "supergraph": "src/index.ts"
  },
  "scripts": {
    "start": "bun serve.ts",
    "build": "bun build --compile --minify src/index.ts --outfile bin/supergraph",
    "release": "npm version patch --no-git-tag-version && git add package.json && git commit -m \"release: v$(jq -r .version package.json)\" && git push",
    "test": "bun test --recursive",
    "typecheck": "bun run --filter='*' typecheck",
    "audit-prep": "bun scripts/audit-prep.ts",
    "supergraph": "bun scripts/supergraph.ts",
    "pkg-graph": "bun scripts/pkg-graph.ts",
    "check-health": "bun scripts/check-health.ts"
  },
  "devDependencies": {
    "bun-types": "latest"
  }
}
